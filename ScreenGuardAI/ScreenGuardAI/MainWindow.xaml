<Window x:Class="ScreenGuardAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenGuard AI - Interview Assistant"
        Width="660" Height="580"
        MinWidth="540" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        ShowInTaskbar="False"
        FontFamily="Consolas, Cascadia Code, Courier New">
    <Window.BorderBrush>
        <SolidColorBrush Color="#0D3A0D"/>
    </Window.BorderBrush>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="[ ScreenGuard AI ]" FontSize="22" FontWeight="Bold" Foreground="#00FF41"
                           FontFamily="Consolas, Cascadia Code, Courier New"/>
                <TextBlock Text="&gt; Interview Assistant :: Capture. Analyze. Answer." FontSize="11" 
                           Foreground="#1A6B1A" Margin="0,2,0,0" FontFamily="Consolas"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="[ Profile ]" Padding="10,5" Margin="0,0,4,0"
                        Background="#0D2B0D" Foreground="#00FF41" 
                        BorderBrush="#1A5A1A" BorderThickness="1" Click="Profile_Click" Cursor="Hand" 
                        FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"/>
                <Button Content="[ Settings ]" Padding="10,5" Margin="0,0,4,0"
                        Background="#141414" Foreground="#33CC33" 
                        BorderBrush="#1A3A1A" BorderThickness="1" Click="Settings_Click" Cursor="Hand" 
                        FontSize="11" FontFamily="Consolas"/>
                <Button Content="[ Hide ]" Padding="10,5"
                        Background="#141414" Foreground="#33CC33" 
                        BorderBrush="#1A3A1A" BorderThickness="1" Click="MinimizeToTray_Click" Cursor="Hand" 
                        FontSize="11" FontFamily="Consolas"/>
            </StackPanel>
        </Grid>

        <!-- Mode Selection + Protection -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Interview Mode Toggle -->
            <Border Background="#0D0D0D" CornerRadius="4" Padding="12" BorderBrush="#1A3A1A" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="// MODE SELECT" FontSize="11" FontWeight="Bold" Foreground="#00CC33" 
                               Margin="0,0,0,8" FontFamily="Consolas"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="QAModeRadio" Content="  Q&amp;A Interview" 
                                     GroupName="Mode" IsChecked="True"
                                     Foreground="#00FF41" FontSize="12" Margin="0,0,20,0"
                                     Checked="Mode_Changed" Cursor="Hand" FontFamily="Consolas"/>
                        <RadioButton x:Name="CodingModeRadio" Content="  Coding Practical" 
                                     GroupName="Mode"
                                     Foreground="#00FF41" FontSize="12"
                                     Checked="Mode_Changed" Cursor="Hand" FontFamily="Consolas"/>
                    </StackPanel>
                    <!-- Auto-Detect Toggle -->
                    <Border Margin="0,8,0,0" Background="#0A0A0A" CornerRadius="3" Padding="8,5" 
                            BorderBrush="#1A3A1A" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="AutoDetectIndicator" Width="6" Height="6" Fill="#555555" 
                                     Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="AUTO-DETECT LeetCode" FontSize="10" 
                                       Foreground="#1A6B1A" VerticalAlignment="Center" FontFamily="Consolas"/>
                            <Button x:Name="AutoDetectBtn" Grid.Column="2" Content="[ OFF ]" Padding="8,2"
                                    Background="#141414" Foreground="#555555" FontSize="9" FontWeight="Bold"
                                    BorderBrush="#1A3A1A" BorderThickness="1"
                                    Click="AutoDetect_Click" Cursor="Hand" FontFamily="Consolas"/>
                        </Grid>
                    </Border>
                    <!-- Audio Listen Toggle -->
                    <Border Margin="0,6,0,0" Background="#0A0A0A" CornerRadius="3" Padding="8,5" 
                            BorderBrush="#1A3A1A" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="AudioIndicator" Width="6" Height="6" Fill="#555555" 
                                     Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="AUDIO STT (Whisper)" FontSize="10" 
                                       Foreground="#1A6B1A" VerticalAlignment="Center" FontFamily="Consolas"/>
                            <!-- Volume bar -->
                            <Border x:Name="VolumeBorder" Grid.Column="2" Width="40" Height="6" 
                                    Background="#141414" CornerRadius="3" Margin="6,0" VerticalAlignment="Center">
                                <Border x:Name="VolumeBar" Width="0" Height="6" Background="#00FF41" 
                                        CornerRadius="3" HorizontalAlignment="Left"/>
                            </Border>
                            <Button x:Name="ListenBtn" Grid.Column="3" Content="[ OFF ]" Padding="8,2"
                                    Background="#141414" Foreground="#555555" FontSize="9" FontWeight="Bold"
                                    BorderBrush="#1A3A1A" BorderThickness="1"
                                    Click="Listen_Click" Cursor="Hand" FontFamily="Consolas"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Capture Protection (always on) -->
            <Border Grid.Column="1" Background="#0D0D0D" CornerRadius="4" Padding="12" 
                    Margin="8,0,0,0" BorderBrush="#1A3A1A" BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#00FF41" Margin="0,0,8,0"/>
                    <TextBlock Text="SHIELDED" FontSize="10" Foreground="#00FF41" 
                               VerticalAlignment="Center" FontFamily="Consolas" FontWeight="Bold"/>
                    <TextBlock Text=" // all windows" FontSize="9" Foreground="#1A6B1A" 
                               VerticalAlignment="Center" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Capture + AI Trigger -->
        <Border Grid.Row="2" Background="#0D0D0D" CornerRadius="4" Padding="14" Margin="0,0,0,10"
                BorderBrush="#1A3A1A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="ModeDescriptionText" 
                               Text="&gt; Captures screen, finds the interview question, generates a ready-to-read answer" 
                               FontSize="11" Foreground="#33AA33" TextWrapping="Wrap" FontFamily="Consolas"/>
                    <TextBlock Text="&gt; Hotkey: Ctrl+Shift+Q (works globally)" 
                               FontSize="10" Foreground="#1A6B1A" Margin="0,4,0,0" FontFamily="Consolas"/>
                </StackPanel>
                <Button x:Name="CaptureButton" Grid.Column="1" Content="&gt;&gt; EXECUTE" Padding="20,10"
                        Background="#00CC33" Foreground="#0A0A0A" 
                        BorderBrush="#00FF41" BorderThickness="1" FontWeight="Bold" FontSize="13"
                        Click="AskAI_Click" Cursor="Hand" VerticalAlignment="Center" FontFamily="Consolas"/>
            </Grid>
        </Border>

        <!-- Additional Context -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ctx&gt;" Foreground="#1A6B1A" FontSize="11" 
                       VerticalAlignment="Center" Margin="0,0,6,0" FontFamily="Consolas"/>
            <TextBox x:Name="QuestionBox" Grid.Column="1" 
                     Background="#0D0D0D" Foreground="#00FF41" BorderBrush="#1A3A1A" BorderThickness="1"
                     Padding="8,5" FontSize="11" FontFamily="Consolas" CaretBrush="#00FF41"
                     Text="" ToolTip="Optional: add context like 'This is a React position' or 'Focus on system design'"/>
        </Grid>

        <!-- Live Transcript Area -->
        <Border x:Name="TranscriptBorder" Grid.Row="4" Background="#050505" CornerRadius="4" Padding="8" 
                BorderBrush="#0D3A0D" BorderThickness="1" Margin="0,0,0,8"
                MaxHeight="100" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="// LIVE TRANSCRIPT (Whisper STT)" FontSize="9" FontWeight="Bold" 
                               Foreground="#1A6B1A" VerticalAlignment="Center" FontFamily="Consolas"/>
                    <Button x:Name="ClearTranscriptBtn" Grid.Column="1" Content="[ CLEAR ]" Padding="6,2"
                            Background="#141414" Foreground="#555555" BorderBrush="#1A3A1A" BorderThickness="1"
                            FontSize="8" Click="ClearTranscript_Click" Cursor="Hand" FontFamily="Consolas"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="60">
                    <TextBlock x:Name="TranscriptText" TextWrapping="Wrap" 
                               Foreground="#33AA33" FontSize="10" LineHeight="14"
                               FontFamily="Consolas, Cascadia Code, Courier New"
                               Text=""/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Last Response Area -->
        <Border Grid.Row="5" Background="#050505" CornerRadius="4" Padding="12" 
                BorderBrush="#0D3A0D" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ResponseHeaderText" Text="// OUTPUT" FontSize="11" FontWeight="Bold" 
                               Foreground="#1A6B1A" VerticalAlignment="Center" FontFamily="Consolas"/>
                    <Button x:Name="CopyResponseBtn" Grid.Column="1" Content="[ COPY ]" Padding="10,3"
                            Background="#141414" Foreground="#00FF41" BorderBrush="#1A3A1A" BorderThickness="1"
                            FontSize="10" Click="CopyResponse_Click" Cursor="Hand" Visibility="Collapsed" 
                            FontFamily="Consolas"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LastResponseText" TextWrapping="Wrap" 
                               Foreground="#00DD33" FontSize="12" LineHeight="20"
                               FontFamily="Consolas, Cascadia Code, Courier New"
                               Text="&gt; System ready. Press Ctrl+Shift+Q or click EXECUTE during your interview._"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer Status -->
        <Grid Grid.Row="6" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusBarText" Text="READY" FontSize="10" Foreground="#1A6B1A" 
                       VerticalAlignment="Center" FontFamily="Consolas"/>
            <TextBlock Grid.Column="1" Text="[Ctrl+Shift+Q]" FontSize="10" Foreground="#0D3A0D" 
                       VerticalAlignment="Center" FontFamily="Consolas"/>
        </Grid>
    </Grid>
</Window>
