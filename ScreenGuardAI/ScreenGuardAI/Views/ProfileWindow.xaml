<Window x:Class="ScreenGuardAI.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenGuard AI - My Interview Profile"
        Width="600" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="500" MinHeight="500"
        ShowInTaskbar="False"
        Background="#0A0A0A"
        FontFamily="Consolas, Cascadia Code, Courier New">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="[ MY PROFILE ]" FontSize="18" FontWeight="Bold" Foreground="#00FF41" FontFamily="Consolas"/>
            <TextBlock Text="&gt; Fill in your background so AI answers match YOUR experience. Export as .md to reuse anywhere." 
                       FontSize="10" Foreground="#1A6B1A" TextWrapping="Wrap" Margin="0,4,0,0" FontFamily="Consolas"/>
        </StackPanel>

        <!-- Scrollable Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>
                <!-- Name -->
                <TextBlock Text="// Full Name" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="NameBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,10"
                         FontFamily="Consolas" CaretBrush="#00FF41"/>

                <!-- Current Role -->
                <TextBlock Text="// Current Role / Title" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="CurrentRoleBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,10"
                         FontFamily="Consolas" CaretBrush="#00FF41"
                         ToolTip="e.g. Senior Frontend Developer at Company X"/>

                <!-- Years Experience -->
                <TextBlock Text="// Years of Experience" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="ExperienceBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,10"
                         FontFamily="Consolas" CaretBrush="#00FF41" ToolTip="e.g. 5"/>

                <!-- Target Role -->
                <TextBlock Text="// Target Role (Applying For)" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="TargetRoleBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,10"
                         FontFamily="Consolas" CaretBrush="#00FF41"
                         ToolTip="e.g. Full Stack Engineer at Google"/>

                <!-- Tech Stack -->
                <TextBlock Text="// Tech Stack / Skills" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="TechStackBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,10"
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50" MaxHeight="80"
                         FontFamily="Consolas" CaretBrush="#00FF41"
                         ToolTip="e.g. React, TypeScript, Node.js, Python, AWS, Docker, PostgreSQL"/>

                <!-- Key Projects -->
                <TextBlock Text="// Key Projects / Achievements" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="ProjectsBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,10"
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" MaxHeight="100"
                         FontFamily="Consolas" CaretBrush="#00FF41"
                         ToolTip="Describe 2-3 key projects or achievements."/>

                <!-- Education -->
                <TextBlock Text="// Education" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="EducationBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,10"
                         FontFamily="Consolas" CaretBrush="#00FF41"
                         ToolTip="e.g. BS Computer Science, University of XYZ, 2019"/>

                <!-- Strengths -->
                <TextBlock Text="// Key Strengths" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="StrengthsBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,10"
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" MaxHeight="70"
                         FontFamily="Consolas" CaretBrush="#00FF41"
                         ToolTip="e.g. Problem-solving, team leadership, fast learner"/>

                <!-- Work Style -->
                <TextBlock Text="// Work Style / Approach" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="WorkStyleBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,10"
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" MaxHeight="70"
                         FontFamily="Consolas" CaretBrush="#00FF41"
                         ToolTip="e.g. Agile, test-driven development, collaborative"/>

                <!-- Additional Notes -->
                <TextBlock Text="// Additional Notes" Foreground="#33CC33" FontSize="11" Margin="0,0,0,4" FontFamily="Consolas"/>
                <TextBox x:Name="NotesBox" Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" BorderThickness="1" Padding="8,6" FontSize="12" Margin="0,0,0,6"
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" MaxHeight="70"
                         FontFamily="Consolas" CaretBrush="#00FF41"
                         ToolTip="Anything else the AI should know about you"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="EXPORT .md" Padding="14,7" Margin="0,0,6,0"
                    Background="#0D2B0D" Foreground="#00FF41" 
                    BorderBrush="#1A5A1A" BorderThickness="1" FontSize="10" FontWeight="Bold"
                    Click="Export_Click" Cursor="Hand" FontFamily="Consolas"
                    ToolTip="Export profile as a Markdown file"/>
            <Button Grid.Column="1" Content="IMPORT .md" Padding="14,7" Margin="0,0,6,0"
                    Background="#141414" Foreground="#33CC33" 
                    BorderBrush="#1A3A1A" BorderThickness="1" FontSize="10"
                    Click="Import_Click" Cursor="Hand" FontFamily="Consolas"
                    ToolTip="Import from a previously exported Markdown file"/>
            <Button Grid.Column="2" Content="CLEAR" Padding="14,7"
                    Background="#1A0A0A" Foreground="#FF3333" 
                    BorderBrush="#3A1A1A" BorderThickness="1" FontSize="10" FontWeight="Bold"
                    Click="Clear_Click" Cursor="Hand" FontFamily="Consolas"/>

            <Button Grid.Column="4" Content="CANCEL" Padding="16,7" Margin="0,0,8,0"
                    Background="#1A1A1A" Foreground="#555555" 
                    BorderBrush="#2A2A2A" BorderThickness="1" FontSize="10"
                    Click="Cancel_Click" Cursor="Hand" FontFamily="Consolas"/>
            <Button Grid.Column="5" Content="&gt;&gt; SAVE" Padding="16,7"
                    Background="#00CC33" Foreground="#0A0A0A" 
                    BorderBrush="#00FF41" BorderThickness="1" FontSize="10" FontWeight="Bold"
                    Click="Save_Click" Cursor="Hand" FontFamily="Consolas"/>
        </Grid>
    </Grid>
</Window>
