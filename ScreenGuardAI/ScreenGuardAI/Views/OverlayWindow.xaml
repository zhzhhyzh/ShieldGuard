<Window x:Class="ScreenGuardAI.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenGuard AI"
        Width="500" Height="580"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#E8080808" CornerRadius="6" BorderBrush="#0D5A0D" BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.7" Color="#003300"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with mode indicator -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="ModeBadge" Background="#00CC33" CornerRadius="2" Padding="8,3">
                    <TextBlock x:Name="ModeBadgeText" Text="Q&amp;A" FontSize="10" FontWeight="Bold" 
                               Foreground="#0A0A0A" FontFamily="Consolas"/>
                </Border>
                <TextBlock Grid.Column="1" Text="[ ScreenGuard AI ]" FontSize="12" FontWeight="Bold" 
                           Foreground="#1A6B1A" VerticalAlignment="Center" Margin="10,0,0,0" FontFamily="Consolas"/>
                <Button x:Name="CloseBtn" Grid.Column="2" Content="[X]" 
                        Width="30" Height="22" FontSize="10" FontWeight="Bold"
                        Background="Transparent" Foreground="#FF3333" 
                        BorderBrush="Transparent" Click="Close_Click" Cursor="Hand" FontFamily="Consolas"/>
            </Grid>

            <!-- Detected Question (for Q&A mode) -->
            <Border x:Name="QuestionSection" Grid.Row="1" Background="#1A0A0A" CornerRadius="4" 
                    Padding="10" Margin="0,0,0,8" Visibility="Collapsed"
                    BorderBrush="#3A1A1A" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="// DETECTED QUESTION:" FontSize="9" FontWeight="Bold" 
                               Foreground="#FF6B6B" Margin="0,0,0,4" FontFamily="Consolas"/>
                    <TextBlock x:Name="DetectedQuestionText" TextWrapping="Wrap" 
                               Foreground="#FF9999" FontSize="12" FontWeight="SemiBold" LineHeight="18"
                               FontFamily="Consolas"/>
                </StackPanel>
            </Border>

            <!-- Timestamp -->
            <TextBlock x:Name="TimestampText" Grid.Row="2" FontSize="9" 
                       Foreground="#1A5A1A" Margin="0,0,0,6" FontFamily="Consolas"/>

            <!-- Main Response Content -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                <TextBlock x:Name="ResponseText" TextWrapping="Wrap" 
                           Foreground="#00DD33" FontSize="13" LineHeight="22"
                           FontFamily="Consolas, Cascadia Code, Courier New"/>
            </ScrollViewer>

            <!-- Action Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="[ COPY ALL ]" Padding="12,6" Margin="0,0,6,0"
                        Background="#0D2B0D" Foreground="#00FF41" FontWeight="Bold"
                        BorderBrush="#1A5A1A" BorderThickness="1" Click="CopyAll_Click" Cursor="Hand" 
                        FontSize="10" FontFamily="Consolas"/>
                <Button x:Name="CopyCodeBtn" Grid.Column="1" Content="[ COPY CODE ]" Padding="12,6" Margin="0,0,6,0"
                        Background="#00CC33" Foreground="#0A0A0A" FontWeight="Bold"
                        BorderBrush="#00FF41" BorderThickness="1" Click="CopyCode_Click" Cursor="Hand" 
                        FontSize="10" FontFamily="Consolas" Visibility="Collapsed"/>
                <Button Grid.Column="3" Content="DISMISS" Padding="12,6"
                        Background="#1A1A1A" Foreground="#555555" 
                        BorderBrush="#2A2A2A" BorderThickness="1" Click="Close_Click" Cursor="Hand" 
                        FontSize="10" FontFamily="Consolas"/>
            </Grid>
        </Grid>
    </Border>
</Window>
