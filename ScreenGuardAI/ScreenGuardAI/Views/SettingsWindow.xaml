<Window x:Class="ScreenGuardAI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenGuard AI - Settings"
        Width="540" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#0A0A0A"
        FontFamily="Consolas, Cascadia Code, Courier New">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="[ SETTINGS ]" FontSize="20" FontWeight="Bold" 
                   Foreground="#00FF41" Margin="0,0,0,16" FontFamily="Consolas"/>

        <!-- Provider Selection -->
        <TextBlock Grid.Row="1" Text="// AI PROVIDER" Foreground="#33CC33" 
                   FontSize="12" FontWeight="Bold" Margin="0,0,0,6" FontFamily="Consolas"/>
        <ComboBox x:Name="ProviderCombo" Grid.Row="2"
                  Background="#141414" Foreground="#00FF41" 
                  BorderBrush="#1A3A1A" Padding="8,6"
                  FontSize="12" Margin="0,0,0,4" FontFamily="Consolas"
                  SelectionChanged="Provider_Changed">
        </ComboBox>
        
        <!-- Provider Info -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,2,0,12">
            <TextBlock x:Name="ProviderInfoText" Text="" FontSize="10" Foreground="#1A6B1A" FontFamily="Consolas"/>
            <TextBlock x:Name="GetKeyLink" Margin="8,0,0,0" FontSize="10" Cursor="Hand"
                       MouseLeftButtonUp="GetKeyLink_Click" FontFamily="Consolas">
                <Underline>
                    <Run x:Name="GetKeyLinkText" Text="&gt; Get API Key" Foreground="#00FF41"/>
                </Underline>
            </TextBlock>
        </StackPanel>

        <!-- API Key -->
        <TextBlock x:Name="ApiKeyLabel" Grid.Row="4" Text="// API KEY" 
                   Foreground="#33CC33" FontSize="12" FontWeight="Bold" Margin="0,0,0,6" FontFamily="Consolas"/>
        <Grid Grid.Row="5" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="ApiKeyBox" Grid.Column="0" 
                         Background="#0D0D0D" Foreground="#00FF41" 
                         BorderBrush="#1A3A1A" Padding="8,6"
                         FontSize="12" FontFamily="Consolas" CaretBrush="#00FF41"/>
            <Button x:Name="TestButton" Grid.Column="1" Content="[ TEST ]" 
                    Margin="8,0,0,0" Padding="14,6"
                    Background="#0D2B0D" Foreground="#00FF41" 
                    BorderBrush="#1A5A1A" BorderThickness="1" FontWeight="Bold"
                    Click="TestButton_Click" Cursor="Hand" FontFamily="Consolas"/>
        </Grid>

        <!-- Model -->
        <TextBlock Grid.Row="6" Text="// MODEL" Foreground="#33CC33" 
                   FontSize="12" FontWeight="Bold" Margin="0,0,0,6" FontFamily="Consolas"/>
        <ComboBox x:Name="ModelCombo" Grid.Row="7" 
                  Background="#141414" Foreground="#00FF41" 
                  BorderBrush="#1A3A1A" Padding="8,6"
                  FontSize="12" Margin="0,0,0,6" FontFamily="Consolas"/>

        <!-- Free badge -->
        <TextBlock x:Name="FreeBadge" Grid.Row="8" 
                   Text="&gt;&gt; FREE TIER - NO CREDIT CARD REQUIRED" 
                   FontSize="10" Foreground="#00FF41" Margin="0,0,0,8"
                   Visibility="Collapsed" FontFamily="Consolas" FontWeight="Bold"/>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="9" 
                   Foreground="#00FF41" FontSize="11" TextWrapping="Wrap"
                   VerticalAlignment="Bottom" Margin="0,0,0,12" FontFamily="Consolas"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="CANCEL" Padding="20,8" Margin="0,0,10,0"
                    Background="#1A1A1A" Foreground="#555555" 
                    BorderBrush="#2A2A2A" BorderThickness="1" Click="Cancel_Click" Cursor="Hand" 
                    FontFamily="Consolas" FontWeight="Bold"/>
            <Button Content="&gt;&gt; SAVE" Padding="20,8"
                    Background="#00CC33" Foreground="#0A0A0A" 
                    BorderBrush="#00FF41" BorderThickness="1" FontWeight="Bold"
                    Click="Save_Click" Cursor="Hand" FontFamily="Consolas"/>
        </StackPanel>
    </Grid>
</Window>
